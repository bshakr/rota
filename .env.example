# Copy to .env at the repo root and fill in. Both apps read this one file:
#
#   cp .env.example .env
#
# apps/api points dotenv at the repo root (see apps/api/config/application.rb).
# apps/web must do the same in next.config.ts.
#
# .env is gitignored. Never commit real credentials.

# --- Core ---------------------------------------------------------------------------

# DATABASE_URL is for PRODUCTION ONLY. Leave both of these commented out locally.
#
# Development and test get their database names from apps/api/config/database.yml, and
# config/application.rb deletes these two variables outside production so they cannot do
# any harm. Here is the harm they used to do:
#
# A DATABASE_URL names ONE database, and Rails applies it to whichever environment is
# booting. This .env is loaded in test as well as development. So setting it to the
# development database — as this file used to, uncommented — pointed `bundle exec rspec`
# at the DEVELOPMENT database, where Rails' maintain_test_schema! promptly tried to purge
# it. Only an internal Rails guard stopped the wipe, and the failure was swallowed, so
# the suite still printed green while connected to the wrong database.
#
# If you need to reach a non-default Postgres locally, use libpq's PGHOST / PGUSER /
# PGPASSWORD / PGPORT instead. They set the connection, never the database name.
#
# DATABASE_URL=postgres://user:pass@host/houserota_api_production
# QUEUE_DATABASE_URL=postgres://user:pass@host/houserota_api_production_queue

# Public URL of the Next.js app. Baked into every magic link we text out, so a wrong
# value here sends people to a dead host and the text cannot be recalled. Also the
# default CORS origin the API accepts.
APP_URL=http://localhost:3001

# Where the Next.js app finds the Rails API.
API_URL=http://localhost:3000

# Extra browser origins allowed to call the API, comma-separated. Only needed when
# APP_URL isn't the whole story — preview deploys, say. Defaults to APP_URL.
# CORS_ORIGINS=http://localhost:3001,https://houserota-preview.vercel.app

# Production only. This app has no config/credentials.yml.enc — every secret is an env
# var, so there is one place to look. Development and test generate a local secret
# automatically and don't need this set.
# Generate with: cd apps/api && bin/rails secret
# SECRET_KEY_BASE=

# --- WorkOS AuthKit (admin login, lives in Next.js) ---------------------------------

# Rails never calls WorkOS; it verifies the JWT against the JWKS endpoint. Only the
# client id is needed there, to resolve the right JWKS URL.
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me

# AuthKit callback, must match the redirect URI registered in the WorkOS dashboard.
WORKOS_REDIRECT_URI=http://localhost:3001/callback

# Encrypts the AuthKit session cookie. At least 32 characters.
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace_me_with_at_least_32_characters

# --- Twilio (SMS) -------------------------------------------------------------------

# Development does not send texts. It runs a null adapter that writes the rendered body
# to the log and invents a SID, so a `bin/jobs` running against a database full of real
# phone numbers cannot text anybody — whatever the credentials below say. The variables
# are not even read.
#
# Set SMS_ADAPTER=twilio once you want to exercise the wire. Do that with a Twilio *test*
# credential and the magic number +15005550006: real API responses, real error codes,
# nothing delivered. Production always uses the real adapter and refuses to boot with
# SMS_ADAPTER=null, which would mean texting nobody while every dashboard stayed green.
#
# The test suite runs the real adapter on purpose — WebMock is what blocks the network.
# See apps/api/spec/sms/no_live_sms_spec.rb.
# SMS_ADAPTER=twilio

TWILIO_ACCOUNT_SID=ACreplace_me
TWILIO_AUTH_TOKEN=replace_me
# The number reminders are sent from, in E.164. Twilio's magic test number by default.
TWILIO_FROM_NUMBER=+15005550006
